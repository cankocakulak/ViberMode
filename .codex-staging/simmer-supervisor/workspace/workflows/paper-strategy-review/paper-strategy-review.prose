# Simmer Paper Strategy Review
# Offline weekly review workflow for policy recommendations in the canonical simmer-supervisor workspace.

input run_id: "Unique workflow run identifier for this review run"
input workflow_name: "Workflow name for attribution; pass paper-strategy-review unless explicitly overridden"
input review_window_start: "Inclusive ISO timestamp for the review window"
input review_window_end: "Exclusive ISO timestamp for the review window"
input journal_source: "Absolute path to journal entries or a directory of recent journal files"
input portfolio_outcomes_source: "Optional absolute path to recent portfolio outcome data; pass empty string if unavailable"
input skipped_trades_source: "Optional absolute path to recent skipped-trade records; pass empty string if unavailable"
input report_path: "Optional absolute output path for the review report; pass empty string to use the default workspace review path"

let workflow_workspace = "/Users/mcan/.openclaw/agents/simmer-supervisor/workspace"
let strategy_profile_id = "crypto_momentum_v1"
let policy_version = "v1"
let effective_workflow_name = "{workflow_name}"
let default_report_root = "{workflow_workspace}/runtime/reviews"

agent strategy-review-runner:
  model: sonnet
  prompt: """You execute exactly one offline paper-strategy-review cycle inside the simmer-supervisor workspace.

Before acting:
1. Read the referenced data sources and template files.
2. Read workspace config files when review context is relevant:
   - {workflow_workspace}/config/strategy-profiles.yaml
   - {workflow_workspace}/config/tracking-schema.yaml
3. Preserve caller context fields exactly:
   - strategy_profile_id
   - policy_version
   - run_id

Execution rules:
- This workflow never opens a trade.
- This workflow never exits a trade.
- Active profile remains crypto_momentum_v1.
- Do not rotate or auto-activate another profile.
- Do not mutate the live policy automatically.
- Group findings at least by:
  - strategy_profile_id
  - policy_version
  - workflow_name
  - entry_reason
  - exit_reason
- If coverage is thin, report lower confidence with fewer recommendations.
- If optional inputs are empty, ignore them rather than inventing data.
"""

let review_report = session: strategy-review-runner
  prompt: """Run the weekly strategy review analysis and write the report.

Template file:
- /Users/mcan/ViberMode/initiatives/simmer-paper-trading/templates/review-report.yaml

Required input sources:
- journal_source: {journal_source}
- review_window_start: {review_window_start}
- review_window_end: {review_window_end}

Optional input sources:
- portfolio_outcomes_source: {portfolio_outcomes_source}
- skipped_trades_source: {skipped_trades_source}

Required caller context:
- run_id: {run_id}
- workflow_name: {effective_workflow_name}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}

Required analysis rules:
- Analyze only records bound to `strategy_profile_id: crypto_momentum_v1`.
- Group data at least by `strategy_profile_id`, `policy_version`, `workflow_name`, `entry_reason`, and `exit_reason`.
- Include executed trades, skipped trades, exits, invalidations, and no-trade decisions when the source data supports them.
- Keep `best_profiles` and `weak_profiles` limited to the active profile and its observed policy versions in the review window.
- Recommended changes must be phrased as proposals to test, not live mutations.
- `do_not_change` must preserve mandatory dry-run, risk-first sequencing, and the fixed active profile.

Required output shape, aligned to the template:
- review_window
- workflow_name
- profiles_reviewed
- best_profiles
- weak_profiles
- good_patterns
- bad_patterns
- recommended_policy_changes
- changes_to_test_next
- do_not_change

Write the report to:
- a path under `{default_report_root}/YYYY/Www/` derived from `review_window_end` if report_path is empty
- otherwise to {report_path}

Return at least:
- report_path
- review_report
- confidence_note
"""

output workflow_name_output = effective_workflow_name
output run_id_output = run_id
output default_report_root_output = default_report_root
output review_report_output = review_report
