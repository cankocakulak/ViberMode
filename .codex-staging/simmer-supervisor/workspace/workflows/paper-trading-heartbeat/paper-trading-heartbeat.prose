# Simmer Paper Trading Heartbeat
# Primary recurring workflow for one heartbeat cycle in the canonical simmer-supervisor workspace.

input run_id: "Unique workflow run identifier that must be preserved across all decisions"
input workflow_name: "Workflow name for attribution; pass paper-trading-heartbeat unless explicitly overridden"

let workflow_workspace = "/Users/mcan/.openclaw/agents/simmer-supervisor/workspace"
let strategy_profile_id = "crypto_momentum_v1"
let policy_version = "v1"
let venue = "sim"
let domain = "crypto_event_markets"
let candidate_limit = "3"
let effective_workflow_name = "{workflow_name}"

agent heartbeat-runner:
  model: sonnet
  prompt: """You execute exactly one paper-trading heartbeat stage inside the simmer-supervisor workspace.

Before acting:
1. Read the referenced skill file and treat it as the operating contract.
2. Read workspace config files when policy context is relevant:
   - {workflow_workspace}/config/strategy-profiles.yaml
   - {workflow_workspace}/config/tracking-schema.yaml
3. Preserve caller context fields exactly:
   - strategy_profile_id
   - policy_version
   - run_id

Execution rules:
- Venue is always sim.
- Active strategy profile is always crypto_momentum_v1.
- Random strategy selection is forbidden.
- Risk-first sequencing is mandatory.
- Max 1 new trade per heartbeat.
- Never average down.
- Never use rescue logic.
- If an earlier step clearly reports a STOP condition, do not call later skills that would bypass it.
- If an optional input is empty, ignore it rather than inventing detail.
"""

let initial_briefing = session: heartbeat-runner
  prompt: """Step 1: fetch the current Simmer briefing.

Skill name: simmer-briefing
Skill file: {workflow_workspace}/skills/simmer-briefing/SKILL.md

Required input:
- venue: {venue}
- run_id: {run_id}

Required caller context:
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}
- workflow_name: {effective_workflow_name}

Required output:
- normalized briefing with:
  - timestamp
  - positions
  - open_orders
  - risk_alerts
  - opportunities
  - performance
  - portfolio_constraints

If briefing cannot be fetched, return:
- status: STOP_BRIEFING_FAILED
- reason: concise blocker
"""

let risk_review = session: heartbeat-runner
  prompt: """Step 2: run the risk gate against the initial briefing.

Skill name: simmer-risk-manager
Skill file: {workflow_workspace}/skills/simmer-risk-manager/SKILL.md

Required input:
- briefing: {initial_briefing}

Required caller context:
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}
- run_id: {run_id}

Required output:
- new_entries_allowed
- actions
- portfolio_note

If the incoming briefing already reports STOP_BRIEFING_FAILED, do not continue risk evaluation.
Return:
- status: STOP_BRIEFING_FAILED
"""

let risk_block_journal = session: heartbeat-runner
  prompt: """Step 3: if risk blocks new entries, write a journal entry and stop.

Skill name: simmer-journal
Skill file: {workflow_workspace}/skills/simmer-journal/SKILL.md

Inputs:
- briefing: {initial_briefing}
- risk_evaluation: {risk_review}

Required caller context:
- run_id: {run_id}
- workflow_name: {effective_workflow_name}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}

Rules:
- If briefing failed, write a concise journal record for a no-action heartbeat and return STOP_RISK_BLOCKED.
- If risk_evaluation.new_entries_allowed is false, write a concise journal record with:
  - action: skip
  - skip_reason: risk gate blocked new entries
  - result: no_trade
  - portfolio_state derived from briefing and risk evaluation
  Then return:
  - status: STOP_RISK_BLOCKED
- Otherwise do not write a journal entry here. Return:
  - status: CONTINUE
"""

let candidate_selection = session: heartbeat-runner
  prompt: """Step 4 through Step 8: shortlist candidate markets, collect context, plan trades, and select the single best candidate.

Skills involved:
- simmer-market-context
- simmer-trade-planner

Skill files:
- {workflow_workspace}/skills/simmer-market-context/SKILL.md
- {workflow_workspace}/skills/simmer-trade-planner/SKILL.md

Inputs:
- briefing: {initial_briefing}
- risk_evaluation: {risk_review}
- risk_block_gate: {risk_block_journal}

Required caller context:
- run_id: {run_id}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}
- workflow_name: {effective_workflow_name}

Rules:
- If risk_block_gate reports STOP_RISK_BLOCKED, do not continue. Return:
  - status: SKIPPED_BY_RISK_BLOCK
- Shortlist at most {candidate_limit} candidate markets from briefing.opportunities.new_markets.
- Before shortlisting, drop any market whose `domain_match` is not true for `briefing.portfolio_constraints.domain`.
- Before shortlisting, drop any market whose `effective_tradable` is not true.
- Before shortlisting, drop any market whose remaining time is below `briefing.portfolio_constraints.minimum_actionable_minutes_to_resolution`.
- Before shortlisting, drop any market with any of these blockers:
  - `external_price_yes_at_or_above_0.99`
  - `market_closed_or_resolved`
  - `market_state_overrides_timing`
  - `market_id_mismatch`
- For each shortlisted market:
  1. call simmer-market-context
  2. call simmer-trade-planner with market_context + briefing + risk_evaluation
- `market_id` from briefing shortlist remains the lookup key; if native context lookup 404s, rely on the adapter's fallback synthesis rather than swapping identifier surfaces inside the workflow
- If a downstream stage returns a different `market_id` than the shortlisted candidate, reject that candidate immediately and do not call dry-run.
- Keep only proposals strong enough for the active policy envelope.
- Select exactly one best candidate if any valid proposal remains.
- If no candidate is strong enough, return:
  - status: STOP_NO_TRADE
  - skip_reason: no candidate strong enough
  - selected_candidate: null
- If a best candidate exists, return:
  - status: CONTINUE
  - selected_candidate: full chosen proposal

Critical rules:
- Do not select more than one candidate.
- Do not bypass the prior risk gate.
- Preserve strategy_profile_id, policy_version, and run_id in the selected candidate.
"""

let no_trade_journal = session: heartbeat-runner
  prompt: """Step 8b: if no candidate is strong enough, write a journal entry and stop.

Skill name: simmer-journal
Skill file: {workflow_workspace}/skills/simmer-journal/SKILL.md

Inputs:
- briefing: {initial_briefing}
- risk_evaluation: {risk_review}
- candidate_selection: {candidate_selection}

Required caller context:
- run_id: {run_id}
- workflow_name: {effective_workflow_name}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}

Rules:
- If candidate_selection reports STOP_NO_TRADE, write a concise journal record with:
  - action: skip
  - skip_reason: no candidate strong enough
  - result: no_trade
  - portfolio_state derived from briefing and risk evaluation
  Then return:
  - status: STOP_NO_TRADE
- Otherwise return:
  - status: CONTINUE
"""

let dry_run_result = session: heartbeat-runner
  prompt: """Step 9: run dry-run for the selected candidate.

Skill name: simmer-dry-run
Skill file: {workflow_workspace}/skills/simmer-dry-run/SKILL.md

Inputs:
- candidate_selection: {candidate_selection}
- no_trade_gate: {no_trade_journal}

Required caller context:
- run_id: {run_id}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}
- workflow_name: {effective_workflow_name}

Rules:
- If candidate_selection does not report CONTINUE, do not call dry-run. Return:
  - status: SKIPPED_NO_CANDIDATE
- Otherwise call simmer-dry-run with:
  - market_id
  - side
  - size
  - venue: {venue}
  - reasoning
  - source
  - strategy_profile_id
  - policy_version
  - run_id

Required output:
- market_id
- estimated_cost
- estimated_shares
- slippage_notes
- policy_pass
- policy_fail_reason
"""

let dry_run_fail_journal = session: heartbeat-runner
  prompt: """Step 10: if dry-run fails policy, write a journal entry and stop.

Skill name: simmer-journal
Skill file: {workflow_workspace}/skills/simmer-journal/SKILL.md

Inputs:
- candidate_selection: {candidate_selection}
- dry_run_result: {dry_run_result}

Required caller context:
- run_id: {run_id}
- workflow_name: {effective_workflow_name}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}

Rules:
- If dry_run_result.policy_pass is false, write a concise journal record with:
  - action: skip
  - skip_reason: dry-run policy failure
  - result: no_trade
  Then return:
  - status: STOP_DRY_RUN_FAILED
- Otherwise return:
  - status: CONTINUE
"""

let execution_result = session: heartbeat-runner
  prompt: """Step 11: execute the approved paper trade.

Skill name: simmer-executor
Skill file: {workflow_workspace}/skills/simmer-executor/SKILL.md

Inputs:
- candidate_selection: {candidate_selection}
- dry_run_result: {dry_run_result}
- dry_run_gate: {dry_run_fail_journal}

Required caller context:
- run_id: {run_id}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}

Rules:
- If dry_run_gate reports STOP_DRY_RUN_FAILED, do not call executor. Return:
  - status: SKIPPED_DRY_RUN_FAILED
- Otherwise call simmer-executor with:
  - market_id
  - side
  - size
  - venue: {venue}
  - reasoning
  - source
  - dry_run_reference
  - strategy_profile_id
  - policy_version
  - run_id

Required output:
- trade_id
- market_id
- status
- filled_size
- average_price
- exposure_after_trade
"""

let refreshed_briefing = session: heartbeat-runner
  prompt: """Step 12: refresh the Simmer briefing after execution.

Skill name: simmer-briefing
Skill file: {workflow_workspace}/skills/simmer-briefing/SKILL.md

Inputs:
- execution_result: {execution_result}

Required caller context:
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}
- run_id: {run_id}
- workflow_name: {effective_workflow_name}

Rules:
- If execution_result reports SKIPPED_DRY_RUN_FAILED or another non-executed status, return:
  - status: SKIPPED_NO_EXECUTION
- Otherwise call simmer-briefing with:
  - venue: {venue}
  - run_id: {run_id}
"""

let final_journal = session: heartbeat-runner
  prompt: """Step 13: write the final heartbeat journal entry.

Skill name: simmer-journal
Skill file: {workflow_workspace}/skills/simmer-journal/SKILL.md

Inputs:
- candidate_selection: {candidate_selection}
- dry_run_result: {dry_run_result}
- execution_result: {execution_result}
- refreshed_briefing: {refreshed_briefing}

Required caller context:
- run_id: {run_id}
- workflow_name: {effective_workflow_name}
- strategy_profile_id: {strategy_profile_id}
- policy_version: {policy_version}

Rules:
- If execution_result reports a real executed trade, write the final journal record with:
  - attribution fields
  - executed trade identifiers
  - thesis / invalidation
  - result
  - refreshed portfolio_state
- If the run already stopped earlier and a journal entry was already written, return:
  - status: NO_FINAL_JOURNAL_NEEDED
"""

output workflow_name_output = effective_workflow_name
output run_id_output = run_id
output initial_briefing_output = initial_briefing
output risk_review_output = risk_review
output candidate_selection_output = candidate_selection
output dry_run_output = dry_run_result
output execution_output = execution_result
output refreshed_briefing_output = refreshed_briefing
output final_journal_output = final_journal
