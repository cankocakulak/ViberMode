# Copy to runtime/env/simmer.env or export these vars in your shell.
# Prefer storing SIMMER_API_KEY in macOS Keychain:
#   security add-generic-password -U -s simmer-supervisor -a SIMMER_API_KEY -w 'sk_live_...'

SIMMER_API_BASE_URL=https://api.simmer.markets
# SIMMER_API_KEY=sk_live_replace_me

# Optional overrides
# SIMMER_AUTH_HEADER=Authorization
# SIMMER_AUTH_SCHEME=Bearer
# SIMMER_TIMEOUT_MS=15000
# SIMMER_HEALTH_PATH=/api/sdk/health
# SIMMER_BRIEFING_PATH=/api/sdk/briefing
# SIMMER_DRY_RUN_PATH=/api/sdk/trades/batch
# SIMMER_EXECUTE_PATH=/api/sdk/trade
