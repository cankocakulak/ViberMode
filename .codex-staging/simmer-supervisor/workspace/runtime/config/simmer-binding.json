{
  "bindingVersion": 1,
  "transport": "http-json",
  "venue": "sim",
  "domain": "crypto_event_markets",
  "defaultApiBaseUrl": "https://api.simmer.markets",
  "apiBaseUrlEnv": "SIMMER_API_BASE_URL",
  "apiKeyEnv": "SIMMER_API_KEY",
  "apiKeyKeychainService": "simmer-supervisor",
  "apiKeyKeychainAccount": "SIMMER_API_KEY",
  "authHeader": "Authorization",
  "authScheme": "Bearer",
  "timeoutMs": 60000,
  "endpoints": {
    "health": {
      "method": "GET",
      "path": "/api/sdk/health"
    },
    "briefing": {
      "method": "GET",
      "path": "/api/sdk/briefing"
    },
    "getMarket": {
      "method": "GET",
      "path": "/api/sdk/markets/{market_id}"
    },
    "searchMarkets": {
      "method": "GET",
      "path": "/api/sdk/markets"
    },
    "positions": {
      "method": "GET",
      "path": "/api/sdk/positions"
    },
    "trades": {
      "method": "GET",
      "path": "/api/sdk/trades"
    },
    "context": {
      "method": "GET",
      "path": "/api/sdk/context/{market_id}"
    },
    "dryRun": {
      "method": "POST",
      "path": "/api/sdk/trades/batch"
    },
    "execute": {
      "method": "POST",
      "path": "/api/sdk/trade"
    }
  },
  "fallbackDiscovery": {
    "crypto_event_markets": {
      "queries": ["bitcoin", "ethereum", "solana", "dogecoin"],
      "limit": 8
    }
  },
  "binaryMarketExecution": {
    "supportsExplicitClose": true,
    "closeEndpoint": "execute",
    "closeAction": "sell",
    "closeSizingField": "shares",
    "supportsDryRunClose": true,
    "reduceExitMode": "explicit_sell_shares",
    "grossExposureGuard": true
  },
  "storage": {
    "journalRoot": "runtime/journals",
    "reviewRoot": "runtime/reviews",
    "runRoot": "runtime/runs"
  }
}
