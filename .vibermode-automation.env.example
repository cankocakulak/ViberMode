# Copy to .vibermode-automation.env and fill locally.
# Do not commit live secrets or account-specific identifiers.

# App Store Connect
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_API_KEY_P8_B64=
ASC_VENDOR_NUMBERS=

# Google Play reports
GOOGLE_PLAY_BUCKET=
GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=

# Notion direct API writes
NOTION_API_KEY=
NOTION_APP_DOWNLOADS_DATABASE_ID=

# Meta Ads reporting
# Keep live Meta tokens in Keychain when possible:
#   viberboyz-meta-access-token
#   viberboyz-meta-ad-account-id
#   viberboyz-meta-app-id
#   viberboyz-meta-app-secret
META_API_VERSION=v21.0
META_KEYCHAIN_PREFIX=viberboyz-meta
# Optional when using existing non-standard Keychain service names:
# META_KEYCHAIN_ACCOUNT=
# META_ACCESS_TOKEN_KEYCHAIN_SERVICE=
# META_AD_ACCOUNT_ID_KEYCHAIN_SERVICE=
# META_APP_ID_KEYCHAIN_SERVICE=
# META_APP_SECRET_KEYCHAIN_SERVICE=
# Direct env fallback is supported but should stay local-only:
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=act_...
# META_APP_ID=
# META_APP_SECRET=

# JSON array of tracked apps. Each object supports:
# key, notionName, iosSku, iosAppleId, androidPackage
# Alternatively, keep the same JSON in an ignored file and set:
# STORE_DOWNLOADS_TRACKED_APPS_FILE=.store-downloads-apps.json
STORE_DOWNLOADS_TRACKED_APPS_JSON='[
  {
    "key": "example-app",
    "notionName": "Example App İndirme",
    "iosSku": "com.example.ios",
    "iosAppleId": "1234567890",
    "androidPackage": "com.example.android"
  }
]'
