# Copy to .vibermode-automation.env and fill locally.
# Do not commit live secrets or account-specific identifiers.

# App Store Connect
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_API_KEY_P8_B64=
ASC_VENDOR_NUMBERS=

# Google Play reports
GOOGLE_PLAY_BUCKET=
GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=
# daily_user_installs, daily_device_installs, install_events,
# store_listing_acquisitions, or total_store_acquisitions
STORE_DOWNLOADS_ANDROID_METRIC=daily_device_installs
# monday or sunday
STORE_DOWNLOADS_WEEK_START_DAY=monday
# true prevents writing partial recent Android weeks. Keep false to write the
# latest available Android data and emit a warning if the week is incomplete.
STORE_DOWNLOADS_REQUIRE_ANDROID_WEEK_COMPLETE=false
# Number of recent completed weeks to re-check on each automation run.
STORE_DOWNLOADS_BACKFILL_WEEKS=4

# Notion direct API writes
# Prefer a Notion Personal Access Token here (`ntn_...`).
# Internal integrations may require manually sharing the target database/page
# with the integration before the script can query or write it.
# Optional Keychain fallback is also supported through:
#   NOTION_KEYCHAIN_SERVICE
#   NOTION_API_KEY_KEYCHAIN_SERVICE
#   NOTION_TOKEN_KEYCHAIN_SERVICE
# or the default service names:
#   viberboyz-notion-api-key
#   vibermode-notion-api-key
#   notion-api-key
#   viberboyz-notion-token
#   vibermode-notion-token
#   notion-token
NOTION_API_KEY=
NOTION_APP_DOWNLOADS_DATABASE_ID=

# Meta Ads reporting
# Keep live Meta tokens in Keychain when possible:
#   viberboyz-meta-access-token
#   viberboyz-meta-ad-account-id
#   viberboyz-meta-app-id
#   viberboyz-meta-app-secret
META_API_VERSION=v21.0
META_KEYCHAIN_PREFIX=viberboyz-meta
# Optional when using existing non-standard Keychain service names:
# META_KEYCHAIN_ACCOUNT=
# META_ACCESS_TOKEN_KEYCHAIN_SERVICE=
# META_AD_ACCOUNT_ID_KEYCHAIN_SERVICE=
# META_APP_ID_KEYCHAIN_SERVICE=
# META_APP_SECRET_KEYCHAIN_SERVICE=
# Direct env fallback is supported but should stay local-only:
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=act_...
# META_APP_ID=
# META_APP_SECRET=

# TikTok Ads reporting
# Keep live TikTok tokens in Keychain when possible:
#   viberboyz-tiktok-access-token
#   viberboyz-tiktok-advertiser-id
#   viberboyz-tiktok-app-id
#   viberboyz-tiktok-app-secret
TIKTOK_API_VERSION=v1.3
TIKTOK_KEYCHAIN_PREFIX=viberboyz-tiktok
TIKTOK_REPORT_TYPE=BASIC
TIKTOK_DATA_LEVEL=AUCTION_AD
TIKTOK_REPORT_DIMENSIONS=campaign_id,adgroup_id,ad_id,stat_time_day
TIKTOK_REPORT_METRICS=spend,impressions,clicks,ctr,cpc,cpm,conversion,cost_per_conversion
# Optional when using existing non-standard Keychain service names:
# TIKTOK_KEYCHAIN_ACCOUNT=
# TIKTOK_ACCESS_TOKEN_KEYCHAIN_SERVICE=
# TIKTOK_ADVERTISER_ID_KEYCHAIN_SERVICE=
# TIKTOK_APP_ID_KEYCHAIN_SERVICE=
# TIKTOK_APP_SECRET_KEYCHAIN_SERVICE=
# Direct env fallback is supported but should stay local-only:
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_ADVERTISER_ID=
# TIKTOK_APP_ID=
# TIKTOK_APP_SECRET=

# Google Ads reporting
# Keep live Google Ads tokens and service account JSON in Keychain when possible:
#   viberboyz-google-ads-developer-token
#   viberboyz-google-ads-customer-id
#   viberboyz-google-ads-login-customer-id
#   viberboyz-google-ads-service-account-json-b64
#   viberboyz-google-ads-client-id
#   viberboyz-google-ads-client-secret
#   viberboyz-google-ads-refresh-token
GOOGLE_ADS_API_VERSION=v24
GOOGLE_ADS_KEYCHAIN_PREFIX=viberboyz-google-ads
# Optional when using existing non-standard Keychain service names:
# GOOGLE_ADS_KEYCHAIN_ACCOUNT=
# GOOGLE_ADS_DEVELOPER_TOKEN_KEYCHAIN_SERVICE=
# GOOGLE_ADS_CUSTOMER_ID_KEYCHAIN_SERVICE=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID_KEYCHAIN_SERVICE=
# GOOGLE_ADS_SERVICE_ACCOUNT_JSON_B64_KEYCHAIN_SERVICE=
# GOOGLE_ADS_CLIENT_ID_KEYCHAIN_SERVICE=
# GOOGLE_ADS_CLIENT_SECRET_KEYCHAIN_SERVICE=
# GOOGLE_ADS_REFRESH_TOKEN_KEYCHAIN_SERVICE=
# Direct env fallback is supported but should stay local-only:
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_JSON_KEY_FILE_PATH=
# GOOGLE_ADS_SERVICE_ACCOUNT_JSON_B64=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=

# JSON array of tracked apps. Each object supports:
# key, notionName, iosSku, iosAppleId, androidPackage
# Alternatively, keep the same JSON in an ignored file and set:
# STORE_DOWNLOADS_TRACKED_APPS_FILE=.store-downloads-apps.json
STORE_DOWNLOADS_TRACKED_APPS_JSON='[
  {
    "key": "example-app",
    "notionName": "Example App İndirme",
    "iosSku": "com.example.ios",
    "iosAppleId": "1234567890",
    "androidPackage": "com.example.android"
  }
]'
