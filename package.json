{
  "name": "viber-mode",
  "version": "0.1.0",
  "description": "Vendor-agnostic AI agent development framework",
  "private": true,
  "type": "module",
  "exports": {
    "./packs/*": "./packs/*",
    "./adapters/*": "./adapters/*",
    "./scripts/*": "./scripts/*"
  },
  "files": [
    "packs",
    "adapters",
    "docs",
    "scripts"
  ],
  "scripts": {
    "install:codex": "bash adapters/codex/install/install-skills.sh",
    "change-release:gate": "node scripts/change-release-gate-check.mjs",
    "app:resolve": "node scripts/app-autopilot-resolve.mjs",
    "research:ingest": "node scripts/ingest-market-source.mjs",
    "research:public-scan": "node scripts/research-public-app-scan.mjs",
    "workspace:topology": "node scripts/workspace-topology.mjs",
    "workspace:provision": "node scripts/workspace-bundle-provision.mjs",
    "factory:experience-gate": "node scripts/ios-factory-experience-gate.mjs",
    "export:idea-to-testflight": "node scripts/export-idea-to-testflight-visual.mjs",
    "export:idea-to-testflight:png": "node scripts/export-idea-to-testflight-png.mjs",
    "export:idea-to-testflight:all": "npm run export:idea-to-testflight && npm run export:idea-to-testflight:png",
    "revenuecat": "node scripts/revenuecat-api.mjs",
    "revenuecat:status": "node scripts/revenuecat-api.mjs status",
    "revenuecat:projects": "node scripts/revenuecat-api.mjs projects",
    "store-downloads:notion": "node scripts/store-downloads-to-notion.mjs",
    "store-downloads:notion:manual": "node scripts/store-downloads-to-notion.mjs --backfill-weeks 4",
    "store-downloads:notion:android-backfill": "node scripts/store-downloads-to-notion.mjs --backfill-weeks 4 --skip-ios --allow-android-overwrite",
    "store-downloads:notion:overwrite": "node scripts/store-downloads-to-notion.mjs --backfill-weeks 4 --allow-overwrite",
    "reviews:stores": "node scripts/store-review-ops.mjs",
    "reviews:stores:reply": "node scripts/store-review-ops.mjs --reply",
    "validate:references": "node scripts/validate-reference-map.mjs",
    "validate:task-phases": "node scripts/validate-task-phases.mjs",
    "validate": "npm run validate:references && npm run validate:task-phases"
  },
  "keywords": [
    "ai",
    "agents",
    "cursor",
    "codex",
    "framework"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
