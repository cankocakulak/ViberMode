{
  "name": "viber-mode",
  "version": "0.1.0",
  "description": "Vendor-agnostic AI agent development framework",
  "private": true,
  "type": "module",
  "exports": {
    "./packs/*": "./packs/*",
    "./adapters/*": "./adapters/*",
    "./scripts/*": "./scripts/*"
  },
  "files": [
    "packs",
    "adapters",
    "docs",
    "scripts"
  ],
  "scripts": {
    "install:codex": "bash adapters/codex/install/install-skills.sh",
    "change-release:gate": "node scripts/change-release-gate-check.mjs",
    "export:idea-to-testflight": "node scripts/export-idea-to-testflight-visual.mjs",
    "export:idea-to-testflight:png": "node scripts/export-idea-to-testflight-png.mjs",
    "export:idea-to-testflight:all": "npm run export:idea-to-testflight && npm run export:idea-to-testflight:png",
    "revenuecat": "node scripts/revenuecat-api.mjs",
    "revenuecat:status": "node scripts/revenuecat-api.mjs status",
    "revenuecat:projects": "node scripts/revenuecat-api.mjs projects",
    "store-downloads:notion": "node scripts/store-downloads-to-notion.mjs",
    "validate:references": "node scripts/validate-reference-map.mjs",
    "validate": "npm run validate:references"
  },
  "keywords": [
    "ai",
    "agents",
    "cursor",
    "codex",
    "framework"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
